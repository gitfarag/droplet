# Caddy developent file easyapply
#dash-dev
dash-dev.{$DOMAIN_NAME:domain.invalid} {
    # http refirect
    reverse_proxy frontend-dev:80
}

# api-dev
rest-dev.{$DOMAIN_NAME:domain.invalid} {  
    reverse_proxy api-dev:9000
    header {
        -X-Powered-By
        -Server
        Strict-Transport-Security max-age=31536000;
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
    }
    rate_limit {
        zone api_limit {
            key {http.request.header.CF-Connecting-IP}
            events 100
            window 1m
        }

        zone burst_limit {
            key {http.request.header.CF-Connecting-IP}
            events 20
            window 1s
        }
    }
}

#dash-dev
dash-staging.{$DOMAIN_NAME:domain.invalid} {
    # http refirect
    reverse_proxy frontend-staging:80
}

# api-dev
rest-staging.{$DOMAIN_NAME:domain.invalid} {  
